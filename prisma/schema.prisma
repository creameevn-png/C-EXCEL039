generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum VaiTro {
  Admin
  CSKH
  GDV
  KeToan
  MuaHang
  KhoTQ
  KhoVN
  Customer
}

enum TrangThaiUser {
  HoatDong
  TamKhoa
}

enum TrangThaiDon {
  DonMoiTao
  DatCoc
  DaMuaHang
  NccGiaoHang
  KhoTqNhan
  DangVanChuyen
  KhoVnNhan
  ChoThanhToan
  GiaoHang
  HoanThanh
  Huy
  KHTuDat
}

enum Tuyen {
  HaNoi
  HCM
}

enum LineVC {
  LineNhanh
  LineThuong
  LineRe
}

enum TrangThaiKN {
  ChoXuLy
  DangXuLy
  DangDuyetCap1
  DangDuyetCap2
  DuyetDoiTra
  DuyetHoanTien
  DuyetGiamGia
  TuChoi
  DaXuLy
}

enum LoaiKN {
  HangLoi
  ThieuHang
  GiaoSai
  KhongNhan
  Khac
}

enum LoaiViTxn {
  Nap
  Tru
}

enum LoaiThuChi {
  Thu
  Chi
}

enum LoaiChungTu {
  HoaDon
  PhieuThu
  PhieuChi
  HopDong
  Khac
}

enum TrangThaiYC {
  ChoXuLy
  DaLienHe
  DaTaoDon
  TuChoi
}

model NhanVien {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  passwordHash String        @map("password_hash")
  hoTen        String        @map("ho_ten")
  vaiTro       VaiTro        @map("vai_tro")
  trangThai    TrangThaiUser @default(HoatDong) @map("trang_thai")
  createdAt    DateTime      @default(now()) @map("created_at")

  // Góp ý NV #52, #53 — tỉ lệ tính thù lao cuối tháng, admin đặt cho từng người:
  // GDV: hoa hồng = doanh số đơn mình phụ trách × pctHoaHong%.
  // CSKH: thưởng  = tổng các loại phí trên đơn mình tạo × pctThuong%.
  pctHoaHong   Float         @default(0) @map("pct_hoa_hong")
  pctThuong    Float         @default(0) @map("pct_thuong")

  ordersCreated DonHang[]    @relation("DonHang_NV")
  ordersGDV     DonHang[]    @relation("DonHang_GDV")
  walletTxns    GiaoDichVi[]
  payments      ThanhToan[]
  gioMuaHo      GioMuaHo[]

  @@index([email])
  @@map("nhan_vien")
}

model KhachHang {
  id         Int      @id @default(autoincrement())
  maKH       String   @unique @map("ma_kh")
  tenKH      String   @map("ten_kh")
  sdt        String?
  email      String?
  diaChi     String?  @map("dia_chi")
  tuyen      Tuyen    @default(HaNoi)
  pctCoc     Float    @default(70) @map("pct_coc")
  soDuVi     Float    @default(0) @map("so_du_vi")
  congNo     Float    @default(0) @map("cong_no")
  tongDon    Int      @default(0) @map("tong_don")
  doanhThu   Float    @default(0) @map("doanh_thu")
  // Đợt bổ sung (yêu cầu Zalo 18/07) — phí riêng theo từng khách (null = dùng % chung của hệ thống)
  // và GDV được phân công phụ trách khách này (null = chưa phân, mọi GDV thấy như cũ).
  phiMuaPctRieng Float? @map("phi_mua_pct_rieng")
  phiBhPctRieng  Float? @map("phi_bh_pct_rieng")
  // Đợt 3B — bật/tắt bảo hiểm riêng cho khách (null = theo công ty · true = bật · false = tắt)
  baoHiemRieng   Boolean? @map("bao_hiem_rieng")
  gdvPhuTrachId  Int?   @map("gdv_phu_trach_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  orders     DonHang[]
  walletTxns GiaoDichVi[]
  khieuNai   KhieuNai[]
  chungTu    ChungTu[]

  @@index([maKH])
  @@index([sdt])
  @@map("khach_hang")
}

model SanPham {
  id          Int      @id @default(autoincrement())
  maSP        String   @unique @map("ma_sp")
  tenSP       String   @map("ten_sp")
  danhMuc     String?  @map("danh_muc")
  webNguon    String?  @map("web_nguon")
  kgGoiY      Float    @default(0) @map("kg_goi_y")
  m3GoiY      Float    @default(0) @map("m3_goi_y")
  giaThamKhao Float    @default(0) @map("gia_tham_khao")
  linkTaobao  String?  @map("link_taobao") @db.Text
  ghiChu      String?  @map("ghi_chu") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("san_pham")
}

model NCC {
  id        Int      @id @default(autoincrement())
  maNCC     String?  @unique @map("ma_ncc")
  tenNCC    String   @map("ten_ncc")
  wechat    String?
  ghiChu    String?  @map("ghi_chu") @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@map("ncc")
}

model DonHang {
  id          Int          @id @default(autoincrement())
  maDH        String       @unique @map("ma_dh")
  ngayTao     DateTime     @default(now()) @map("ngay_tao")
  maKH        String       @map("ma_kh")
  nvTao       String?      @map("nv_tao")
  nvId        Int?         @map("nv_id")
  // Góp ý NV #12 — GDV được CSKH giao phụ trách đơn này (nền tảng tính hoa hồng #52).
  gdvId       Int?         @map("gdv_id")
  tuyen       Tuyen        @default(HaNoi)

  maGD        String?      @map("ma_gd") @db.Text
  maVD        String?      @map("ma_vd") @db.Text

  // Đợt 2 — giá vốn GDV (đơn vị: tệ NDT). lợi nhuận = tệ khách trả − (vốn mua + ship nội địa TQ)
  vonNDT      Float        @default(0) @map("von_ndt")
  shipNDTQ    Float        @default(0) @map("ship_nd_tq")
  loiNhuanNDT Float        @default(0) @map("loi_nhuan_ndt")

  tongKg      Float        @default(0) @map("tong_kg")
  tongM3      Float        @default(0) @map("tong_m3")
  tongGiaHang Float        @default(0) @map("tong_gia_hang")
  phiMua      Float        @default(0) @map("phi_mua")
  phiBH       Float        @default(0) @map("phi_bh")
  // Đợt 3B — đè bảo hiểm riêng cho đơn này (null = theo khách/công ty · true/false = ép riêng đơn)
  coBaoHiem   Boolean?     @map("co_bao_hiem")
  phiPhatSinh Float        @default(0) @map("phi_phat_sinh")
  // Góp ý NV #9 — CSKH nhập phí phát sinh, chỉ khi Kế toán duyệt mới cộng vào tổng tiền.
  phiPhatSinhDuyet   Boolean   @default(false) @map("phi_phat_sinh_duyet")
  phiPhatSinhDuyetBy String?   @map("phi_phat_sinh_duyet_by")
  phiPhatSinhDuyetAt DateTime? @map("phi_phat_sinh_duyet_at")
  // Góp ý NV #47 — phí đổi trả khách phải chịu, ghi cột riêng để tách sổ chi phí
  // khiếu nại (#49) nhưng vẫn cộng vào khoản Kế toán cần thu.
  phiKhieuNai Float        @default(0) @map("phi_khieu_nai")
  phiVC       Float        @default(0) @map("phi_vc")
  shipND      Float        @default(0) @map("ship_nd")
  dongGo      Float        @default(0) @map("dong_go")
  phuThu      Float        @default(0) @map("phu_thu")
  thueNK      Float        @default(0) @map("thue_nk")
  vat         Float        @default(0) @map("vat")
  phiKiemHoa  Float        @default(0) @map("phi_kiem_hoa")
  phiLuuKho   Float        @default(0) @map("phi_luu_kho")
  ngachHQ     String       @default("Tiểu ngạch") @map("ngach_hq")

  // Đợt 3 — dịch vụ GTGT kiểm đếm + thông tin người nhận hàng (mặc định theo KH, sửa được)
  kiemDem     Boolean      @default(false) @map("kiem_dem")
  nguoiNhan   String?      @map("nguoi_nhan")
  sdtNhan     String?      @map("sdt_nhan")
  diaChiNhan  String?      @map("dia_chi_nhan") @db.Text

  // Đợt 3B — khóa cân: chốt khi Kho VN xác nhận nhận hàng (hoặc kho bấm "Chốt cân").
  // Sau khi canDaChot = true, chỉ Admin được sửa cân (nhân viên kho bị chặn).
  canDaChot   Boolean      @default(false) @map("can_da_chot")
  canChotBy   String?      @map("can_chot_by")
  canChotAt   DateTime?    @map("can_chot_at")

  // Đợt 4 — kho TQ: người phụ trách nhận (2 NV kho)
  // Góp ý NV #32 — tách "người trực tiếp làm" và "người phụ trách" (kho TQ có 2 nhân viên).
  nguoiPhuTrachTQ String?  @map("nguoi_phu_trach_tq")
  nguoiLamTQ      String?  @map("nguoi_lam_tq")

  // Đợt 5 — đơn thuộc bao tổng nào (gộp nhiều đơn → 1 bao chuyển về VN)
  maBao       String?      @map("ma_bao")

  // Đợt 6 — đơn thuộc phiếu giao gộp nào
  maPhieuGiao String?      @map("ma_phieu_giao")
  tongTien    Float        @default(0) @map("tong_tien")
  tienCoc     Float        @default(0) @map("tien_coc")
  daTra       Float        @default(0) @map("da_tra")
  conLai      Float        @default(0) @map("con_lai")

  trangThai   TrangThaiDon @default(DonMoiTao) @map("trang_thai")
  lineVC      LineVC       @default(LineThuong) @map("line_vc")
  loaiHang    String       @default("Thường") @map("loai_hang")
  pctCoc      Float        @default(70) @map("pct_coc")

  anhKhoTQ    String?      @map("anh_kho_tq") @db.Text
  anhRoiTQ    String?      @map("anh_roi_tq") @db.Text
  anhKhoVN    String?      @map("anh_kho_vn") @db.Text
  anhGiaoKH   String?      @map("anh_giao_kh") @db.Text

  ghiChu      String?      @map("ghi_chu") @db.Text

  // Đợt 11 — góp ý NV #14, #41: ghi chú riêng của GDV (tách khỏi ghi chú CSKH/khách)
  // và line vận chuyển nội địa VN do kho VN chọn khi giao hàng.
  ghiChuGDV   String?      @map("ghi_chu_gdv") @db.Text
  lineNoiDia  String?      @map("line_noi_dia")

  updatedAt   DateTime     @updatedAt @map("updated_at")

  khachHang KhachHang   @relation(fields: [maKH], references: [maKH])
  nv        NhanVien?   @relation("DonHang_NV", fields: [nvId], references: [id])
  gdv       NhanVien?   @relation("DonHang_GDV", fields: [gdvId], references: [id])
  chiTiet   ChiTietDon[]
  kienHang  KienHang[]
  payments  ThanhToan[]
  khieuNai  KhieuNai[]
  chungTu   ChungTu[]

  @@index([gdvId])
  @@index([maKH, ngayTao(sort: Desc)])
  @@index([trangThai, ngayTao(sort: Desc)])
  @@index([ngayTao(sort: Desc)])
  @@map("don_hang")
}

model ChiTietDon {
  id         Int      @id @default(autoincrement())
  maDH       String   @map("ma_dh")
  stt        Int
  tenSP      String   @map("ten_sp") @db.Text
  soLuong    Int      @default(1) @map("so_luong")
  donGiaNDT  Float    @default(0) @map("don_gia_ndt")
  tyGia      Float    @default(3650) @map("ty_gia")
  donGiaVND  Float    @default(0) @map("don_gia_vnd")
  thanhTien  Float    @default(0) @map("thanh_tien")
  // Góp ý NV #13 — tiền tệ (¥) GDV mua thực tế của TỪNG sản phẩm.
  // Giá vốn đơn = Σ vonNDT các dòng (nếu GDV nhập theo dòng).
  vonNDT     Float    @default(0) @map("von_ndt")
  kg         Float    @default(0)
  m3         Float    @default(0)
  // Góp ý NV #33 — kích thước thực đo; m³ suy ra = dài×rộng×cao / hệ số (cài đặt "m3_chia").
  dai        Float    @default(0)
  rong       Float    @default(0)
  cao        Float    @default(0)
  webNguon   String?  @map("web_nguon")
  linkTaobao String?  @map("link_taobao") @db.Text
  ghiChu     String?  @map("ghi_chu") @db.Text
  // Đợt 4 — kiểm đếm tại kho TQ theo từng link sản phẩm: "Đủ" | "Thiếu" | null
  kiemKe     String?  @map("kiem_ke")
  kiemKeNote String?  @map("kiem_ke_note") @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  donHang DonHang @relation(fields: [maDH], references: [maDH], onDelete: Cascade)

  @@index([maDH, stt])
  @@map("chi_tiet_don")
}

/// Góp ý NV #28, #37, #38 — mỗi mã vận đơn của một đơn hàng là một KIỆN riêng.
/// Kho VN quét mã bao → quét từng mã VĐ để xác nhận nhận (#28); bắn mã từng kiện
/// khi giao khách (#37); đơn về một phần thì giao trước các kiện đã về (#38).
/// Kiện được sinh tự động từ ô "mã vận đơn" của GDV (nhiều mã, cách nhau dấu phẩy).
model KienHang {
  id        Int       @id @default(autoincrement())
  maDH      String    @map("ma_dh")
  maVD      String    @map("ma_vd")
  kg        Float     @default(0)
  m3        Float     @default(0)
  maBao     String?   @map("ma_bao")
  /// ChuaVe | DaVeVN | DaGiao
  trangThai String    @default("ChuaVe") @map("trang_thai")
  ngayVeVN  DateTime? @map("ngay_ve_vn")
  ngayGiao  DateTime? @map("ngay_giao")
  nguoiNhan String?   @map("nguoi_nhan")
  nguoiGiao String?   @map("nguoi_giao")
  ghiChu    String?   @map("ghi_chu") @db.Text
  createdAt DateTime  @default(now()) @map("created_at")

  donHang DonHang @relation(fields: [maDH], references: [maDH], onDelete: Cascade)

  // map: đặt đúng tên ràng buộc dưới DB cho khớp 15_gopy_hoan_thien.sql (chống schema drift).
  @@unique([maDH, maVD], name: "uq_kien_don_vd", map: "uq_kien_don_vd")
  @@index([maVD])
  @@index([trangThai])
  @@map("kien_hang")
}

/// Góp ý NV #22, #42, #43 — sổ quỹ thu-chi.
///   quy = "CongTy" → định khoản thu chi nội bộ công ty (Kế toán ghi, #22).
///   quy = "KhoVN" | "KhoTQ" → quỹ của kho: kho thu hộ khách, chi tiền ship (#42);
///   chính tài khoản kho xem được sổ quỹ của mình (#43), Kế toán xem tất cả.
model SoQuy {
  id        Int        @id @default(autoincrement())
  ngay      DateTime   @default(now())
  quy       String     @default("CongTy")
  loai      LoaiThuChi @default(Thu)
  soTien    Float      @default(0) @map("so_tien")
  danhMuc   String?    @map("danh_muc")
  noiDung   String     @map("noi_dung") @db.Text
  maDH      String?    @map("ma_dh")
  maKH      String?    @map("ma_kh")
  nguoiTao  String?    @map("nguoi_tao")
  createdAt DateTime   @default(now()) @map("created_at")

  @@index([quy, ngay(sort: Desc)])
  @@index([ngay(sort: Desc)])
  @@map("so_quy")
}

/// Đợt 6 — phiếu giao gộp nhiều đơn của 1 khách; công nợ tính theo phiếu.
model PhieuGiao {
  id        Int      @id @default(autoincrement())
  maPhieu   String   @unique @map("ma_phieu")
  maKH      String   @map("ma_kh")
  tenKH     String?  @map("ten_kh")
  soDon     Int      @default(0) @map("so_don")
  tongTien  Float    @default(0) @map("tong_tien")
  daThu     Float    @default(0) @map("da_thu")
  conLai    Float    @default(0) @map("con_lai")
  nguoiTao  String?  @map("nguoi_tao")
  ghiChu    String?  @map("ghi_chu") @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@index([maKH, createdAt(sort: Desc)])
  @@map("phieu_giao")
}

/// Đợt 5 — bao tổng (lô/chuyến): gộp nhiều đơn theo line, đóng 1 mã bao, xuất về VN.
model BaoTong {
  id          Int       @id @default(autoincrement())
  maBao       String    @unique @map("ma_bao")
  line        LineVC    @default(LineThuong)
  trangThai   String    @default("DangDong") @map("trang_thai") // DangDong | DaXuat | DaVeVN | HoanThanh
  tongKg      Float     @default(0) @map("tong_kg")
  tongM3      Float     @default(0) @map("tong_m3")
  soKien      Int       @default(0) @map("so_kien")
  ghiChu      String?   @map("ghi_chu") @db.Text
  nguoiTao    String?   @map("nguoi_tao")
  nguoiNhanVN String?   @map("nguoi_nhan_vn")
  createdAt   DateTime  @default(now()) @map("created_at")
  xuatAt      DateTime? @map("xuat_at")
  veVNAt      DateTime? @map("ve_vn_at")

  @@index([trangThai, createdAt(sort: Desc)])
  @@map("bao_tong")
}

/// Đợt 4 — hàng "vô chủ": mã VĐ về kho TQ nhưng chưa khớp đơn nào; khi tìm ra đơn sẽ gán vào.
model HangVoChu {
  id        Int      @id @default(autoincrement())
  maVD      String   @map("ma_vd")
  kg        Float    @default(0)
  dai       Float    @default(0)
  rong      Float    @default(0)
  cao       Float    @default(0)
  m3        Float    @default(0)
  anh       String?  @db.Text
  ghiChu    String?  @map("ghi_chu") @db.Text
  daGan     Boolean  @default(false) @map("da_gan")
  maDH      String?  @map("ma_dh")
  nguoiNhap String?  @map("nguoi_nhap")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([daGan, createdAt(sort: Desc)])
  @@map("hang_vo_chu")
}

model GiaoDichVi {
  id        Int        @id @default(autoincrement())
  ngay      DateTime   @default(now())
  maKH      String     @map("ma_kh")
  loai      LoaiViTxn
  soTien    Float      @map("so_tien")
  soDuSau   Float      @default(0) @map("so_du_sau")
  quy       String?    @map("quy")
  ghiChu    String?    @map("ghi_chu") @db.Text
  nv        String?
  nvId      Int?       @map("nv_id")

  khachHang KhachHang @relation(fields: [maKH], references: [maKH])
  nhanVien  NhanVien? @relation(fields: [nvId], references: [id])

  @@index([maKH, ngay(sort: Desc)])
  @@map("lich_su_vi")
}

model ThanhToan {
  id        Int        @id @default(autoincrement())
  ngay      DateTime   @default(now())
  maDH      String     @map("ma_dh")
  loai      LoaiThuChi @default(Thu)
  soTien    Float      @map("so_tien")
  ghiChu    String?    @map("ghi_chu") @db.Text
  nv        String?
  nvId      Int?       @map("nv_id")

  donHang DonHang  @relation(fields: [maDH], references: [maDH])
  nhanVien NhanVien? @relation(fields: [nvId], references: [id])

  @@index([maDH])
  @@map("thu_chi")
}

model CaiDat {
  id     Int     @id @default(autoincrement())
  ten    String  @unique
  giaTri String? @map("gia_tri") @db.Text
  ghiChu String? @map("ghi_chu") @db.Text

  @@map("cai_dat")
}

model HoatDong {
  id        Int      @id @default(autoincrement())
  ngay      DateTime @default(now())
  email     String?
  hanhDong  String   @map("hanh_dong")
  doiTuong  String?  @map("doi_tuong")
  chiTiet   String?  @map("chi_tiet") @db.Text

  @@index([ngay(sort: Desc)])
  @@map("hoat_dong")
}

model KhieuNai {
  id            Int          @id @default(autoincrement())
  maKN          String       @unique @map("ma_kn")
  ngayTao       DateTime     @default(now()) @map("ngay_tao")
  maDH          String?      @map("ma_dh")
  maKH          String?      @map("ma_kh")
  nguoiTao      String?      @map("nguoi_tao")
  loai          LoaiKN
  moTa          String       @map("mo_ta") @db.Text
  anhBangChung  String?      @map("anh_bang_chung") @db.Text
  trangThai     TrangThaiKN  @default(ChoXuLy) @map("trang_thai")
  phuongAn      String?      @map("phuong_an")
  soTienHoan    Float        @default(0) @map("so_tien_hoan")
  // Đợt 7 — đổi/trả: phí ship đổi-trả, hoàn tiền vào ví KH (tự động khi duyệt cấp 2),
  // tách chi phí khiếu nại theo quỹ chịu (Shop tự chịu / NCC / Quỹ kho / KH chịu).
  phiDoiTra     Float        @default(0) @map("phi_doi_tra")
  hoanVi        Boolean      @default(false) @map("hoan_vi")
  daHoanVi      Boolean      @default(false) @map("da_hoan_vi")
  quyChiuPhi    String?      @map("quy_chiu_phi")
  // Khi quỹ chịu = NCC: tên NCC/shop gánh chi phí + cờ đã cấn trừ vào sổ công nợ NCC.
  doiTacNCC     String?      @map("doi_tac_ncc")
  daTruNCC      Boolean      @default(false) @map("da_tru_ncc")
  // Góp ý NV #45 — CSKH tiếp nhận kiện khiếu nại rồi chuyển về kho VN (kèm mã VĐ khách gửi lại).
  maVDTraHang   String?      @map("ma_vd_tra_hang")
  chuyenKhoVN   Boolean      @default(false) @map("chuyen_kho_vn")
  chuyenKhoVNAt DateTime?    @map("chuyen_kho_vn_at")
  // Góp ý NV #44 — kho VN bắn mã VĐ trả hàng và tích đã nhận hàng khiếu nại.
  daNhanHangKN  Boolean      @default(false) @map("da_nhan_hang_kn")
  ngayNhanKN    DateTime?    @map("ngay_nhan_kn")
  nguoiNhanKN   String?      @map("nguoi_nhan_kn")
  // Góp ý NV #47 — cờ chống cộng trùng phí đổi trả vào khoản phải thu của khách.
  daTinhPhiKH   Boolean      @default(false) @map("da_tinh_phi_kh")
  ghiChuXuLy    String?      @map("ghi_chu_xu_ly") @db.Text
  duyetCap1By   String?      @map("duyet_cap1_by")
  duyetCap1At   DateTime?    @map("duyet_cap1_at")
  duyetCap1Note String?      @map("duyet_cap1_note") @db.Text
  duyetCap2By   String?      @map("duyet_cap2_by")
  duyetCap2At   DateTime?    @map("duyet_cap2_at")
  duyetCap2Note String?      @map("duyet_cap2_note") @db.Text
  updatedAt     DateTime     @updatedAt @map("updated_at")

  donHang   DonHang?   @relation(fields: [maDH], references: [maDH])
  khachHang KhachHang? @relation(fields: [maKH], references: [maKH])

  @@index([maDH])
  @@index([trangThai])
  @@index([ngayTao(sort: Desc)])
  @@map("khieu_nai")
}

model BangGia {
  id              Int      @id @default(autoincrement())
  line            LineVC
  loaiHang        String   @map("loai_hang")
  giaKgDuoi5      Float    @default(0) @map("gia_kg_duoi_5")
  giaKg5To20      Float    @default(0) @map("gia_kg_5_20")
  giaKgTren20     Float    @default(0) @map("gia_kg_tren_20")
  giaM3           Float    @default(0) @map("gia_m3")
  phiPhuPct       Float    @default(0) @map("phi_phu_pct")
  thoiGianDuKien  String?  @map("thoi_gian_du_kien")
  hoatDong        Boolean  @default(true) @map("hoat_dong")
  ghiChu          String?  @map("ghi_chu") @db.Text
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([line, loaiHang], name: "uq_bang_gia_line_loai")
  @@map("bang_gia")
}

/// Đợt 8 — bảng giá mua hàng theo website nguồn (tỷ giá + % phí mua + phí tối thiểu).
/// Giúp CSKH/Mua hàng báo giá nhất quán theo từng sàn (1688/Taobao/Tmall/Alibaba…).
model BangGiaWeb {
  id        Int      @id @default(autoincrement())
  web       String   @unique
  tyGia     Float    @default(3650) @map("ty_gia")
  phiMuaPct Float    @default(0) @map("phi_mua_pct")
  phiMuaMin Float    @default(0) @map("phi_mua_min")
  ghiChu    String?  @map("ghi_chu") @db.Text
  hoatDong  Boolean  @default(true) @map("hoat_dong")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("bang_gia_web")
}

/// Đợt 8 — sổ công nợ nhà cung cấp / shop TQ theo từng shop + theo đơn.
/// loai: "PhatSinh" (mua hàng → tăng nợ phải trả) | "ThanhToan" (trả NCC → giảm nợ).
model CongNoNCC {
  id        Int      @id @default(autoincrement())
  ngay      DateTime @default(now())
  doiTac    String   @map("doi_tac")
  web       String?
  maDH      String?  @map("ma_dh")
  loai      String   @default("PhatSinh")
  soTien    Float    @default(0) @map("so_tien")
  soTienNDT Float    @default(0) @map("so_tien_ndt")
  tyGia     Float    @default(0) @map("ty_gia")
  ghiChu    String?  @map("ghi_chu") @db.Text
  nguoiTao  String?  @map("nguoi_tao")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([doiTac, ngay(sort: Desc)])
  @@map("cong_no_ncc")
}

model NguonHang {
  id           Int      @id @default(autoincrement())
  tenSP        String   @map("ten_sp")
  danhMuc      String?  @map("danh_muc")
  tenNCC       String?  @map("ten_ncc")
  linkTaobao   String?  @map("link_taobao") @db.Text
  giaNDT       Float?   @map("gia_ndt")
  moq          Int      @default(1)
  thoiGianGiao String?  @map("thoi_gian_giao")
  chatLuong    Int?     @map("chat_luong")
  ghiChu       String?  @map("ghi_chu") @db.Text
  nguoiThem    String?  @map("nguoi_them")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("nguon_hang")
}

model YeuCauMua {
  id        Int         @id @default(autoincrement())
  maYC      String      @unique @map("ma_yc")
  ngayTao   DateTime    @default(now()) @map("ngay_tao")
  hoTen     String      @map("ho_ten")
  sdt       String
  email     String?
  maKH      String?     @map("ma_kh")
  tuyen     Tuyen       @default(HaNoi)
  sanPham   String      @map("san_pham") @db.Text
  ghiChu    String?     @map("ghi_chu") @db.Text
  trangThai TrangThaiYC @default(ChoXuLy) @map("trang_thai")
  nvXuLy    String?     @map("nv_xu_ly")
  ghiChuXuLy String?    @map("ghi_chu_xu_ly") @db.Text
  maDH      String?     @map("ma_dh")
  updatedAt DateTime    @updatedAt @map("updated_at")

  @@index([trangThai])
  @@index([ngayTao(sort: Desc)])
  @@map("yeu_cau_mua")
}

/// Giỏ "mua hộ" — sản phẩm nhân viên Mua hàng thêm từ extension 1688/Taobao/Tmall.
model GioMuaHo {
  id          Int       @id @default(autoincrement())
  nvId        Int       @map("nv_id")
  source      String    @default("") // 1688 | taobao | tmall
  productId   String?   @map("product_id")
  productUrl  String?   @map("product_url") @db.Text
  title       String    @db.Text
  titleVi     String?   @map("title_vi") @db.Text // tên dịch sang tiếng Việt (extension tự dịch)
  image       String?   @db.Text
  images      String?   @db.Text // JSON array URL
  priceText   String?   @map("price_text")
  priceValue  Float?    @map("price_value")
  currency    String?   @default("CNY")
  quantity    Int       @default(1)
  minQuantity Int       @default(1) @map("min_quantity")
  sku         String?   @db.Text // JSON array
  skuText     String?   @map("sku_text") @db.Text
  danhMuc     String?   @map("danh_muc") // phân loại danh mục hàng hoá (giống gaudonhaphang)
  note        String?   @db.Text // ghi chú cho nhân viên mua hàng
  ghiChuRiengTu String? @map("ghi_chu_rieng_tu") @db.Text // ghi chú riêng tư
  fromListing Boolean   @default(false) @map("from_listing")
  raw         String?   @db.Text // JSON probe gốc
  daXuLy      Boolean   @default(false) @map("da_xu_ly") // đã chuyển thành đơn chưa
  capturedAt  DateTime? @map("captured_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  nhanVien NhanVien @relation(fields: [nvId], references: [id], onDelete: Cascade)

  @@index([nvId, createdAt(sort: Desc)])
  @@map("gio_mua_ho")
}

/// Đợt 10 — thông báo nội bộ (notify gần realtime qua polling). vaiTro = đối tượng
/// nhận (null = mọi vai trò). Trạng thái "đã đọc" lưu client-side theo mốc lastSeen.
model ThongBao {
  id        Int      @id @default(autoincrement())
  ngay      DateTime @default(now())
  vaiTro    String?  @map("vai_tro")
  loai      String   @default("info")
  tieuDe    String   @map("tieu_de")
  noiDung   String?  @map("noi_dung") @db.Text
  link      String?
  maDH      String?  @map("ma_dh")
  nguoiTao  String?  @map("nguoi_tao")

  @@index([vaiTro, ngay(sort: Desc)])
  @@index([ngay(sort: Desc)])
  @@map("thong_bao")
}

model ChungTu {
  id        Int          @id @default(autoincrement())
  maCT      String       @unique @map("ma_ct")
  ngay      DateTime     @default(now())
  loai      LoaiChungTu
  maDH      String?      @map("ma_dh")
  maKH      String?      @map("ma_kh")
  tieuDe    String       @map("tieu_de")
  noiDung   String?      @map("noi_dung") @db.Text
  fileUrl   String?      @map("file_url") @db.Text
  nguoiTao  String?      @map("nguoi_tao")
  createdAt DateTime     @default(now()) @map("created_at")

  donHang   DonHang?   @relation(fields: [maDH], references: [maDH])
  khachHang KhachHang? @relation(fields: [maKH], references: [maKH])

  @@map("chung_tu")
}

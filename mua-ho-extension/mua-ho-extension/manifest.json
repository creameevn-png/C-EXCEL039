{
  "manifest_version": 3,
  "name": "Mua Hộ - 1688, Taobao & Tmall",
  "version": "2.0.0",
  "description": "Thêm sản phẩm 1688 / Taobao / Tmall vào giỏ hàng hệ thống mua hộ: nút trên trang chi tiết + thêm nhanh từ trang tìm kiếm, tự bắt phân loại (SKU) và số lượng tối thiểu.",
  "default_locale": "vi",
  "permissions": ["storage", "scripting", "activeTab"],
  "host_permissions": [
    "https://*.1688.com/*",
    "https://*.taobao.com/*",
    "https://*.tmall.com/*",
    "http://localhost:3000/*",
    "https://cuexcel.vercel.app/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Mua Hộ",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.1688.com/*",
        "https://*.taobao.com/*",
        "https://*.tmall.com/*"
      ],
      "js": ["content/extractors.js", "content/content.js", "content/listing.js"],
      "css": ["content/inject.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/page-probe.js"],
      "matches": [
        "https://*.1688.com/*",
        "https://*.taobao.com/*",
        "https://*.tmall.com/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}

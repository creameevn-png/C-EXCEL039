{
  "manifest_version": 3,
  "name": "Mua Hộ Cừ - 1688, Taobao & Tmall",
  "version": "2.7.1",
  "description": "Khách mua hộ từ 1688 / Taobao / Tmall: bấm 'Tôi muốn đặt sản phẩm này' để thêm vào GIỎ, gom nhiều sản phẩm rồi 'Gửi tất cả' gộp thành 1 yêu cầu. Xem giá VNĐ (tỉ giá hệ thống), tự dịch tiếng Trung sang tiếng Việt, chọn danh mục, ghi chú; xem 'Yêu cầu của tôi'.",
  "permissions": ["storage", "scripting", "activeTab"],
  "host_permissions": [
    "https://*.1688.com/*",
    "https://*.taobao.com/*",
    "https://*.tmall.com/*",
    "https://translate.googleapis.com/*",
    "http://localhost:3000/*",
    "https://cuexcel.vercel.app/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Mua Hộ Cừ",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.1688.com/*",
        "https://*.taobao.com/*",
        "https://*.tmall.com/*"
      ],
      "js": ["content/extractors.js", "content/content.js", "content/listing.js"],
      "css": ["content/inject.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/page-probe.js"],
      "matches": [
        "https://*.1688.com/*",
        "https://*.taobao.com/*",
        "https://*.tmall.com/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
